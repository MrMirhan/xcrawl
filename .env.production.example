# ============================================================================
# XCrawl — production environment template.
# Copy this file to `.env` on the server and fill in the values marked
# `replace_me_*`. Do NOT commit your filled `.env`.
#
#   cp .env.production.example .env
#   ${EDITOR:-vi} .env
# ============================================================================

# ----- Domain ---------------------------------------------------------------
# The single hostname that points to this server. Caddy obtains a Let's
# Encrypt certificate for this domain automatically. Set an A/AAAA record
# at your DNS provider pointing to the server's public IP first.
XCRAWL_DOMAIN=xcrawl.example.com

# ----- Auth -----------------------------------------------------------------
# JWT signing key. MUST be a strong random secret.
#   openssl rand -hex 32
JWT_SECRET=replace_me_openssl_rand_hex_32

# Initial admin user. Created on first `pnpm run db:seed` (or by exec'ing
# into the api container — see docs/deployment.md).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me_strong_password

# ----- Database -------------------------------------------------------------
POSTGRES_USER=xcrawl
POSTGRES_PASSWORD=replace_me_strong_password
POSTGRES_DB=xcrawl
# DATABASE_URL is built from the values above inside docker-compose.yml.
# Override it here only if you point at an external Postgres.
# DATABASE_URL=postgresql://xcrawl:replace_me_strong_password@postgres:5432/xcrawl

# ----- Redis ----------------------------------------------------------------
# Internal Docker hostname. Change only if you point at an external Redis.
REDIS_URL=redis://redis:6379

# ----- Storage --------------------------------------------------------------
# `local` keeps scraped artifacts on a Docker volume. `s3` uses the bundled
# Garage instance (enable with `--profile s3`) or any external S3 endpoint
# (MinIO, AWS S3, Cloudflare R2).
STORAGE_PROVIDER=local

# S3 mode — uncomment the block below and set STORAGE_PROVIDER=s3.
# S3_ENDPOINT=http://garage:3900
# S3_BUCKET=xcrawl
# S3_ACCESS_KEY=replace_me
# S3_SECRET_KEY=replace_me
# S3_REGION=garage

# ----- SearXNG --------------------------------------------------------------
# Used by the /search endpoint. Internal hostname; do not change unless you
# point at an external SearXNG.
SEARXNG_URL=http://searxng:8080
# Required by SearXNG itself.
#   openssl rand -hex 32
SEARXNG_SECRET=replace_me_openssl_rand_hex_32

# ----- Rate limiting --------------------------------------------------------
# Per-IP requests per window. Anonymous limit applies to unauthenticated
# requests (signin, signup).
RATE_LIMIT_MAX=100
RATE_LIMIT_MAX_ANON=20
RATE_LIMIT_WINDOW_SECS=60

# ----- Crawler --------------------------------------------------------------
CRAWLER_MAX_CONCURRENCY=10
CRAWLER_DEFAULT_TIMEOUT=30000
CRAWLER_HEADLESS=true

# ----- Cache / cleanup ------------------------------------------------------
# Redis cache TTL for repeat scrapes (seconds).
CACHE_TTL_SECS=3600
# Job results older than this are pruned by the cleanup worker (hours).
CLEANUP_TTL_HOURS=168

# ----- Cloudflare Tunnel (alternative to public Caddy) ---------------------
# Only used if you switch to the `cloudflared` service in docker-compose.yml.
# Create a tunnel in the Cloudflare dashboard (Zero Trust -> Networks ->
# Tunnels) and paste its token here.
# TUNNEL_TOKEN=eyJh...
