# API
API_PORT=3001
NODE_ENV=development

# REQUIRED — generate a strong random secret (e.g., openssl rand -hex 32)
JWT_SECRET=

# CORS — comma-separated origins, or leave empty for permissive (dev only)
# CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://xcrawl:xcrawl@localhost:5432/xcrawl
POSTGRES_USER=xcrawl
POSTGRES_PASSWORD=xcrawl
POSTGRES_DB=xcrawl
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Crawler
CRAWLER_MAX_CONCURRENCY=10
CRAWLER_DEFAULT_TIMEOUT=30000
CRAWLER_HEADLESS=true

# Storage
STORAGE_PROVIDER=local
STORAGE_PATH=./data/storage

# S3 (optional — enable with STORAGE_PROVIDER=s3, uses Garage)
S3_ENDPOINT=http://localhost:3900
S3_BUCKET=xcrawl
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# SearXNG
SEARXNG_URL=http://localhost:8888
SEARXNG_SECRET=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECS=60

# Cache
CACHE_TTL_SECS=3600

# Cleanup
CLEANUP_TTL_HOURS=168

# Seed (used by `pnpm run db:seed`) — set a strong password!
ADMIN_EMAIL=admin@xcrawl.local
ADMIN_PASSWORD=

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Note: LLM config (provider, API key, model) and proxy URLs
# are per-user settings — configure them in the dashboard after login.
