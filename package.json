{
  "name": "xcrawl",
  "author": {
    "name": "MrMirhan",
    "url": "https://github.com/MrMirhan",
    "email": "me@example.com"
  },
  "version": "1.0.0",
  "private": true,
  "description": "Open-source web crawling and scraping platform",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "dotenv -- turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "dotenv -- pnpm --filter @xcrawl/db generate",
    "db:migrate": "dotenv -- pnpm --filter @xcrawl/db migrate",
    "db:push": "dotenv -- pnpm --filter @xcrawl/db push",
    "db:seed": "dotenv -- pnpm --filter @xcrawl/db seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "sharp",
      "msgpackr-extract",
      "@nestjs/core",
      "@scarf/scarf"
    ],
    "overrides": {
      "undici": "^7.28.0",
      "@xmldom/xmldom": "^0.8.13",
      "ws": "^8.21.0",
      "multer": "^2.2.0",
      "tar": "^7.5.19",
      "hono": "^4.12.25",
      "@hono/node-server": "^1.19.10",
      "path-to-regexp": "^8.4.0",
      "handlebars": "^4.7.9",
      "fast-uri": "^3.1.2",
      "form-data": "^4.0.6",
      "defu": "^6.1.5",
      "lodash": "^4.18.0",
      "effect": "^3.20.0",
      "anymatch>picomatch": "^2.3.2",
      "micromatch>picomatch": "^2.3.2",
      "jest-util@29>picomatch": "^2.3.2",
      "@angular-devkit/core>picomatch": "^4.0.4",
      "jest-message-util>picomatch": "^4.0.4",
      "jest-util@30>picomatch": "^4.0.4"
    }
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
